# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit your actual keys.

# College Scorecard API (required for download-scorecard)
# Sign up at: https://api.data.gov/signup/
SCORECARD_API_KEY=your_key_here

# Bureau of Economic Analysis API (required for download-bea)
# Sign up at: https://apps.bea.gov/api/signup/
BEA_API_KEY=your_key_here

# Census API key (optional — increases rate limits for download-saipe)
# Sign up at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# BLS API key (optional — enables v2 API with higher rate limits for download-bls)
# Sign up at: https://www.bls.gov/developers/
BLS_API_KEY=
